#!/usr/bin/env bash
# Independent Hermes for THIS project (own venv + own .hermes home + own skills).
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export HERMES_HOME="$HERE/.hermes"
# Bundled skills live outside .venv (skill discovery excludes .venv paths):
export HERMES_BUNDLED_SKILLS="$HERE/.hermes-skills/skills"
# Plain `if`, not `[ ... ] && export` — under `set -e` a false test exits the script.
if [ -d "$HERE/.hermes-skills/optional-skills" ]; then
  export HERMES_OPTIONAL_SKILLS="$HERE/.hermes-skills/optional-skills"
fi
# Windows venvs put executables in Scripts/; POSIX uses bin/
if [ -d "$HERE/.venv/Scripts" ]; then
  exec "$HERE/.venv/Scripts/hermes" "$@"
else
  exec "$HERE/.venv/bin/hermes" "$@"
fi
